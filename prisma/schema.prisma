// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int     @id @default(autoincrement())
  username      String
  email         String  @unique
  password      String
  level         String  @default("user")
  profile_image String?
  status        String? @default("active")
  
  cart_items    Cart[]
  vouchers      UserVoucher[]
  addresses     Address[]
  wallet        UserWallet?
  orders        Order[]

  @@map("users")
}

model UserWallet {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique
  balance    Float    @default(0)
  pin        String?  // Hashed PIN
  status     String   @default("active")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User     @relation(fields: [user_id], references: [id])

  @@map("user_wallets")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Gender {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]

  @@map("genders")
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  price         Float
  description   String?
  images        String?
  category_id   Int?
  gender_id     Int?
  options       String?
  sizes         String?
  cost_price    Float?    @default(0)
  selling_price Float?    @default(0)
  discount      Float?    @default(0)
  stock         Int?      @default(0)
  variants      String?   // JSON String for advanced variants
  category      Category? @relation(fields: [category_id], references: [id])
  gender        Gender?   @relation(fields: [gender_id], references: [id])
  
  cart_items    Cart[]

  @@map("products")
}

model Cart {
  id           Int      @id @default(autoincrement())
  user_id      Int
  product_id   Int
  type         String   // 'cart' or 'wishlist'
  quantity     Int      @default(1)
  variant_name String?  
  size         String?
  created_at   DateTime @default(now())

  user         User     @relation(fields: [user_id], references: [id])
  product      Product  @relation(fields: [product_id], references: [id])

  @@map("cart")
}

model Order {
  id              Int           @id @default(autoincrement())
  user_id         Int
  order_number    String        @unique
  total_amount    Float
  shipping_fee    Float
  discount_amount Float         @default(0)
  final_amount    Float
  status          String        @default("dikemas")
  payment_method  String        @default("wardanapay")
  payment_status  String        @default("paid")
  
  recipient_name  String
  phone           String
  full_address    String
  
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  user            User          @relation(fields: [user_id], references: [id])
  items           OrderItem[]
  statuses        OrderStatus[]

  @@map("orders")
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  order_id     Int
  product_id   Int
  product_name String
  quantity     Int
  price        Float
  variant      String?
  size         String?
  image        String?

  order        Order    @relation(fields: [order_id], references: [id])

  @@map("order_items")
}

model OrderStatus {
  id          Int      @id @default(autoincrement())
  order_id    Int
  status      String
  description String?
  created_at  DateTime @default(now())

  order       Order    @relation(fields: [order_id], references: [id])

  @@map("order_statuses")
}

model Voucher {
  id                Int      @id @default(autoincrement())
  code              String   @unique
  title             String
  type              String   // 'harga', 'ongkir'
  discount_value    Float
  discount_type     String   // 'fixed', 'percent'
  min_purchase      Float?   @default(0)
  max_discount      Float?
  
  target_user_type  String   @default("all") // 'all', 'specific'
  target_users      String?  // JSON Array of User IDs
  
  target_scope      String   @default("all") // 'all', 'category', 'product'
  target_categories String?  // JSON Array of Category IDs
  target_products   String?  // JSON Array of Product IDs

  start_date        DateTime?
  end_date          DateTime?
  usage_limit       Int?
  used_count        Int      @default(0)
  status            String   @default("active")
  created_at        DateTime @default(now())

  user_vouchers     UserVoucher[]

  @@map("vouchers")
}

model UserVoucher {
  id          Int      @id @default(autoincrement())
  user_id     Int
  voucher_id  Int
  is_used     Boolean  @default(false)
  claimed_at  DateTime @default(now())
  used_at     DateTime?

  user        User     @relation(fields: [user_id], references: [id])
  voucher     Voucher  @relation(fields: [voucher_id], references: [id])

  @@map("user_vouchers")
}

model Address {
  id              Int      @id @default(autoincrement())
  user_id         Int
  label           String   
  recipient_name  String
  phone           String
  province_code   String
  province_name   String
  city_code       String
  city_name       String
  district_code   String
  district_name   String
  village_code    String
  village_name    String
  postal_code     String?
  street_address  String
  is_primary      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user            User     @relation(fields: [user_id], references: [id])

  @@map("addresses")
}
